<Window x:Class="Exam.App.AgentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Агент"
        Width="620" Height="760"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="Наименование" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>
            <TextBlock Text="Тип агента" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Types}" SelectedValue="{Binding Agent.AgentTypeId}" SelectedValuePath="Id" DisplayMemberPath="Title" Margin="0,4,0,12"/>
            <TextBlock Text="Телефон" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Phone}" Margin="0,4,0,12"/>
            <TextBlock Text="Email" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Email}" Margin="0,4,0,12"/>
            <TextBlock Text="Приоритет" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Priority}" Margin="0,4,0,12"/>
            <TextBlock Text="Директор" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Director}" Margin="0,4,0,12"/>
            <TextBlock Text="Адрес" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Address}" Margin="0,4,0,12"/>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ИНН" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Inn}" Margin="0,4,0,12"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="КПП" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Kpp}" Margin="0,4,0,12"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="Логотип" FontWeight="SemiBold"/>
            <DockPanel Margin="0,4,0,18">
                <Button DockPanel.Dock="Right" Content="Заменить" Click="PickLogo_Click" Padding="12,6"/>
                <TextBox Text="{Binding Logo}" Margin="0,0,10,0"/>
            </DockPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" IsDefault="True" Click="Save_Click" Padding="18,8"/>
                <Button Content="Отмена" IsCancel="True" Margin="10,0,0,0" Padding="18,8"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
