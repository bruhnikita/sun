<Window x:Class="Exam.App.SalesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История реализации"
        Width="720" Height="420"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">
    <DockPanel Margin="18">
        <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding SaleDate, StringFormat=d}" Width="130"/>
                <DataGridTextColumn Header="Продукция" Binding="{Binding ProductTitle}" Width="*"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding ProductCount}" Width="120"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat=N2}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
